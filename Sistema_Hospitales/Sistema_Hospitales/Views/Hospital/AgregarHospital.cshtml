@model Sistema_Hospitales.Models.viewModels.mHospital
@{
    ViewBag.Title = "AgregarHospital";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



@if (ViewBag.ValorMensaje == 1)
{

    <div class="modal fade" id="myModal" role="dialog">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                    <div class="modal-title">Mensaje</div>
                </div>
                <div class="modal-body">
                    <div class="alert alert-success">@ViewBag.MensajeProceso</div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-default" data-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}
else
{
    if (ViewBag.ValorMensaje == 0)
    {
        <div class="modal fade" id="myModal" role="dialog">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal">&times;</button>
                        <div class="modal-title">Mensaje</div>
                    </div>
                    <div class="modal-body">
                        <div class="alert alert-danger">@ViewBag.MensajeProceso</div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-default" data-dismiss="modal">Cerrar</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@using (Html.BeginForm("AgregarHospital", "Hospital", FormMethod.Post))
{
    <div class="container">
        <div class="row">

            <div class="col-md-3"></div>
            <div class="col-md-6">
                <br />
                <h2 class="text-success">AgregarHospital</h2>
                <br />
                @Html.LabelFor(u => u.Nombre)
                @Html.TextBoxFor(u => u.Nombre, new { @class = "form-control" })
                @Html.ValidationMessage("nombreHospital")
                <br />

                @Html.LabelFor(u => u.Direccion)
                @Html.TextBoxFor(u => u.Direccion, new { @class = "form-control" })
                @Html.ValidationMessage("direccionHospital")
                <br />

                @Html.LabelFor(u => u.Telefono)
                @Html.TextBoxFor(u => u.Telefono, new { @class = "form-control" })
                @Html.ValidationMessage("telefonoHospital")
                <br />
                <div class="d-flex justify-content-between">
                    <input type="submit" class="btn btn-success btn-block btn-lg" value="Agregar" />
                    <input type="button" value="Volver" class="btn btn-secondary btn-lg" onclick="document.location.href = '@Url.Content("~/Hospital/mantHospitales")'" />
                </div>
            </div>
            <div class="col-md-3"></div>

        </div>
        </div>

}

@section scripts {
    <script type="text/javascript">
        $(document).ready(function () {
            if (@ViewBag.ValorMensaje == 1 || @ViewBag.ValorMensaje == 0) {
                $('#myModal').modal('show');
            }

            // Cerrar modal manualmente si el botón no funciona
            $(".close, .btn-default").on("click", function () {
                $("#myModal").modal("hide");
            });
        });
    </script>
}

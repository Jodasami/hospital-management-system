@model List<Sistema_Hospitales.Models.viewModels.mInventarioPrescripcion>
@{
    ViewBag.Title = "InventarioYPrescripciones";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container mt-4">
    <h2 class="fw-bold text-dark align-content-center">Inventario y Prescripciones</h2>
    <br />

    <div class="shadow rounded-4 bg-secondary p-4 mb-4">
        @using (Html.BeginForm("InventarioYPrescripciones", "Hospital", FormMethod.Get))
        {
            <div class="form-group">
                <label for="idHospital" class="form-label fw-bold">Seleccionar Hospital</label>
                @Html.DropDownList("idHospital", (SelectList)ViewBag.Hospitales, "Seleccione un hospital",
                    new { @class = "form-control form-control-lg", onchange = "this.form.submit();" })
            </div>
        }
    </div>

    @if (ViewBag.IdHospital != null)
    {
        <h3 class="text-dark mb-3">Hospital: @ViewBag.IdHospital</h3>
    }

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger shadow rounded-4">@ViewBag.Error</div>
    }
    else if (Model != null && Model.Any())
    {
        <div class="table-responsive shadow rounded-4 bg-secondary p-3">
            <table class="table table-hover table-secondary table-striped align-middle">
                <thead class="table-dark">
                    <tr class="text-center">
                        <th>ID Medicamento</th>
                        <th>Nombre</th>
                        <th>Cantidad Disponible</th>
                        <th>Cantidad Prescrita (30 días)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="text-center">
                            <td>@item.IdMedicamento</td>
                            <td>@item.Nombre</td>
                            <td>
                                <span class="badge @(item.CantidadDisponible > 10 ? "bg-success" : "bg-warning")">
                                    @item.CantidadDisponible
                                </span>
                            </td>
                            <td>@(item.CantidadPrescritaUltimos30Dias ?? 0)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info shadow rounded-4">
            No hay datos disponibles para mostrar.
        </div>
    }

    <div class="d-flex justify-content-end mt-4">
        <input type="button" value="Volver" class="btn btn-secondary btn-lg"
               onclick="document.location.href = '@Url.Content("~/Home/Dashboard")'" />
    </div>
</div>
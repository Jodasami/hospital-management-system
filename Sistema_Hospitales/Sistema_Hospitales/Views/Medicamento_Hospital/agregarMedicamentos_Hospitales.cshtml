@model Sistema_Hospitales.Models.viewModels.mMedicamento_Hospital
@{
    ViewBag.Title = "agregarMedicamentos_Hospitales";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="text-center mb-4">
        <h2 class="text-success">Agregar Medicamento al Hospital</h2>

        @if (ViewBag.ValorMensaje == 1 || ViewBag.ValorMensaje == 0)
        {
            var modalClass = ViewBag.ValorMensaje == 1 ? "success" : "danger";
            <div class="modal fade" id="myModal" tabindex="-1" role="dialog" aria-labelledby="modalLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered" role="document">
                    <div class="modal-content border-@modalClass">
                        <div class="modal-header bg-@modalClass text-white">
                            <h5 class="modal-title" id="modalLabel">Mensaje del Sistema</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                        </div>
                        <div class="modal-body">
                            <div class="alert alert-@modalClass mb-0">
                                @ViewBag.MensajeProceso
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cerrar</button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="card shadow border-0">
            <div class="card-body">
                @using (Html.BeginForm("agregarMedicamentos_Hospitales", "Medicamento_Hospital", FormMethod.Post))
                {
                    <div class="mb-3">
                        @Html.LabelFor(m => m.IdHospital, "Hospital", new { @class = "form-label fw-bold" })
                        @Html.DropDownListFor(m => m.IdHospital, (IEnumerable<SelectListItem>)ViewBag.ListaHospitales, "Seleccione un hospital", new { @class = "form-select" })
                        @Html.ValidationMessageFor(m => m.IdHospital, null, new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        @Html.LabelFor(m => m.IdMedicamento, "Medicamento", new { @class = "form-label fw-bold" })
                        @Html.DropDownListFor(m => m.IdMedicamento, (IEnumerable<SelectListItem>)ViewBag.ListaMedicamentos, "Seleccione un medicamento", new { @class = "form-select" })
                        @Html.ValidationMessageFor(m => m.IdMedicamento, null, new { @class = "text-danger" })
                    </div>

                    <div class="mb-4">
                        @Html.LabelFor(m => m.CantidadDisponible, new { @class = "form-label fw-bold" })
                        @Html.TextBoxFor(m => m.CantidadDisponible, new { @class = "form-control", type = "number", min = "0" })
                        @Html.ValidationMessageFor(m => m.CantidadDisponible, null, new { @class = "text-danger" })
                    </div>

                    <div class="d-flex justify-content-between">
                        <input type="submit" value="Agregar Medicamento" class="btn btn-success btn-lg px-4" />
                        <input type="button" value="Volver" class="btn btn-secondary btn-lg" onclick="window.location.href='@Url.Action("mantMedicamento_Hospitales", "Medicamento_Hospital")'" />
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script type="text/javascript">
        $(document).ready(function () {
            if (@ViewBag.ValorMensaje == 1 || @ViewBag.ValorMensaje == 0) {
                $('#myModal').modal('show');
            }

            // Cerrar modal manualmente si el botón no funciona
            $(".close, .btn-default").on("click", function () {
                $("#myModal").modal("hide");
            });
        });
    </script>
}




@model Sistema_Hospitales.Models.viewModels.mMedicamento_Hospital
@{
    ViewBag.Title = "consultarMedicamentos_Hospitales";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-success text-white text-center">
                    <h3 class="mb-0">Disponibilidad de Medicamento</h3>
                </div>
                <div class="card-body p-3">
                    <div class="d-flex justify-content-center">
                        <div class="table-responsive">
                            <table class="table table-borderless mx-auto">
                                <tbody>
                                    <tr>
                                        <th class="text-end pe-3">ID Hospital:</th>
                                        <td>@Html.DisplayFor(model => model.IdHospital)</td>
                                    </tr>
                                    <tr>
                                        <th class="text-end pe-3">ID Medicamento:</th>
                                        <td>@Html.DisplayFor(model => model.IdMedicamento)</td>
                                    </tr>
                                    <tr>
                                        <th class="text-end pe-3">Cantidad Disponible:</th>
                                        <td>
                                            <span class="@(Model.CantidadDisponible > 50 ? "text-success" : "text-warning") fw-bold">
                                                @Html.DisplayFor(model => model.CantidadDisponible)
                                            </span>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="text-center mt-4">
                        <a href="@Url.Content("~/Medicamento_Hospital/mantMedicamento_Hospitales")"
                           class="btn btn-secondary btn-lg">
                            Volver
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@model List<Sistema_Hospitales.Models.viewModels.mPago>
@{
    ViewBag.Title = "Pagos Pendientes";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container mt-4">
    <h2 class="fw-bold text-dark align-content-center">Pagos Pendientes</h2>
    <br />

    <div class="table-responsive shadow rounded-4 bg-secondary p-3">
        <table class="table table-hover table-secondary table-striped align-middle">
            <thead class="table-dark">
                <tr class="text-center">
                    <th>Fecha</th>
                    <th>Monto</th>
                    <th>Método de Pago</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pago in Model)
                {
                    <tr class="text-center">
                        <td>@pago.Fecha.ToString("dd-MM-yyyy")</td>
                        <td>@pago.Monto</td>
                        <td>@pago.MetodoPago</td>
                        <td>
                            <form action="@Url.Action("pagar", "Pago")" method="post" class="d-inline">
                                @Html.Hidden("idPago", pago.IdPago)
                                <button type="submit" class="btn btn-outline-success btn-sm">
                                    Pagar
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-end mt-4">
        <input type="button" value="Volver" class="btn btn-secondary btn-lg"
               onclick="document.location.href = '@Url.Content("~/Home/Dashboard")'" />
    </div>
</div>
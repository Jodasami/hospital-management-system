@model Sistema_Hospitales.Models.viewModels.mPago
@{
    ViewBag.Title = "Agregar Pago";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<h2 class="text-center text-success">Agregar Pago</h2>
<br />

@if (ViewBag.ValorMensaje == 1 || ViewBag.ValorMensaje == 0)
{
    <div class="modal fade" id="myModal" role="dialog">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-@(ViewBag.ValorMensaje == 1 ? "success" : "danger") text-white">
                    <h5 class="modal-title">Mensaje</h5>
                    <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-@(ViewBag.ValorMensaje == 1 ? "success" : "danger")">
                        @ViewBag.MensajeProceso
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

@using (Html.BeginForm("agregarPagos", "Pago", FormMethod.Post))
{
    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                @Html.LabelFor(p => p.IdPaciente)
                @Html.TextBoxFor(p => p.IdPaciente, new { @class = "form-control" })
                @Html.ValidationMessageFor(p => p.IdPaciente, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                @Html.LabelFor(p => p.Fecha)
                @Html.TextBoxFor(p => p.Fecha, new { @class = "form-control", type = "date" })
                @Html.ValidationMessageFor(p => p.Fecha, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                @Html.LabelFor(p => p.MetodoPago)
                @Html.TextBoxFor(p => p.MetodoPago, new { @class = "form-control" })
                @Html.ValidationMessageFor(p => p.MetodoPago, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="col-md-6">
            <div class="form-group">
                @Html.LabelFor(p => p.IdTratamiento)
                @Html.TextBoxFor(p => p.IdTratamiento, new { @class = "form-control" })
                @Html.ValidationMessageFor(p => p.IdTratamiento, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                @Html.LabelFor(p => p.Monto)
                @Html.TextBoxFor(p => p.Monto, new { @class = "form-control" })
                @Html.ValidationMessageFor(p => p.Monto, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                @Html.LabelFor(p => p.Pagado)
                @Html.DropDownListFor(p => p.Pagado, new List<SelectListItem>
                {
                    new SelectListItem() { Text = "Sí", Value = "True" },
                    new SelectListItem() { Text = "No", Value = "False" }
                }, new { @class = "form-control" })
                @Html.ValidationMessageFor(p => p.Pagado, "", new { @class = "text-danger" })
            </div>
        </div>
    </div>

    <br />
    <div class="form-group text-center">
        <input type="submit" class="btn btn-success btn-lg mx-2" value="Agregar Pago" />
        <a href="@Url.Action("mantPagos", "Pago")" class="btn btn-secondary btn-lg mx-2">Volver</a>
    </div>
}

@section scripts {
    <script type="text/javascript">
        $(document).ready(function () {
            if (@ViewBag.ValorMensaje == 1 || @ViewBag.ValorMensaje == 0) {
                $('#myModal').modal('show');
            }

            $(".close, .btn-default").on("click", function () {
                $("#myModal").modal("hide");
            });
        });
    </script>
}
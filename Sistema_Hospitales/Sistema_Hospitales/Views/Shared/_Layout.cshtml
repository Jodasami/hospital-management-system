<!DOCTYPE html>
<html lang="es">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Sistema de Hospitales</title>
    <script src="https://website-widgets.pages.dev/dist/sienna.min.js" defer></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/Content/custom-login.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    @*@Styles.Render("~/Content/css")*@
    @Scripts.Render("~/bundles/modernizr")
</head>
<body class="d-flex flex-column min-vh-100">
    @* -------------------------------------------- USUARIO ADMIN -------------------------------------------- *@
    @if (Session["Usuario"] != null && Convert.ToInt32(Session["Rol"]) == 3)
    {

        <nav class="navbar navbar-expand-sm navbar-dark bg-success">
            <div class="container">
                @Html.ActionLink(" Sistema Hospitalario", "Dashboard", "Home", null, new { @class = "navbar-brand bi bi-hospital-fill" })
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContenido1"
                        aria-controls="navbarContenido1" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContenido1">
                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            @Html.ActionLink("Inicio", "Dashboard", "Home", null, new { @class = "nav-link" })
                        </li>

                        @* --- Administración --- *@
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown">
                                Administración
                            </a>
                            <ul class="dropdown-menu">
                                <li>@Html.ActionLink("Hospitales", "mantHospitales", "Hospital", null, new { @class = "dropdown-item" })</li>
                                <li>@Html.ActionLink("Usuarios", "mantUsuarios", "Usuario", null, new { @class = "dropdown-item" })</li>
                            </ul>
                        </li>

                        @* --- Médicos --- *@
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="medicosDropdown" role="button" data-bs-toggle="dropdown">
                                Médicos
                            </a>
                            <ul class="dropdown-menu">
                                <li>@Html.ActionLink("Medicos", "mantMedicos", "Medico", null, new { @class = "dropdown-item" })</li>
                                <li>@Html.ActionLink("Tratamientos", "mantTratamientos", "Tratamiento", null, new { @class = "dropdown-item" })</li>
                                <li>@Html.ActionLink("Citas", "mantCitas", "Cita", null, new { @class = "dropdown-item" })</li>
                            </ul>
                        </li>

                        @* --- Pacientes --- *@
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="pacientesDropdown" role="button" data-bs-toggle="dropdown">
                                Pacientes
                            </a>
                            <ul class="dropdown-menu">
                                <li>@Html.ActionLink("Pacientes", "mantPacientes", "Paciente", null, new { @class = "dropdown-item" })</li>
                                <li>@Html.ActionLink("Pagos", "mantPagos", "Pago", null, new { @class = "dropdown-item" })</li>
                            </ul>
                        </li>

                        @* --- Medicamentos --- *@
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="medicamentosDropdown" role="button" data-bs-toggle="dropdown">
                                Medicamentos
                            </a>
                            <ul class="dropdown-menu">
                                <li>@Html.ActionLink("Medicamentos", "mantMedicamentos", "Medicamento", null, new { @class = "dropdown-item" })</li>
                                <li>@Html.ActionLink("Stock de Medicamentos por Hospital", "mantMedicamento_Hospitales", "Medicamento_Hospital", null, new { @class = "dropdown-item" })</li>
                                <li>@Html.ActionLink("Medicamentos Asignados a Tratamientos", "mantTratamiento_Medicamento", "Tratamiento_Medicamento", null, new { @class = "dropdown-item" })</li>
                            </ul>
                        </li>

                        @* --- Reportes (SP) --- *@
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="reportesDropdown" role="button" data-bs-toggle="dropdown">
                                Reportes
                            </a>
                            <ul class="dropdown-menu">
                                <li>@Html.ActionLink("Pacientes por Médico", "ObtenerPacientesPorMedico", "Cita", null, new { @class = "dropdown-item" })</li>
                                <li>@Html.ActionLink("Inventario y Prescripciones", "InventarioYPrescripciones", "Hospital", null, new { @class = "dropdown-item" })</li>
                                <li>@Html.ActionLink("Pagos Pendientes", "verPagosPaciente", "Pago", null, new { @class = "dropdown-item" })</li>
                                <li>@Html.ActionLink("Pagos por Rango", "TotalPagos", "Pago", null, new { @class = "dropdown-item" })</li>
                            </ul>
                        </li>

                        @* --- Cierre --- *@
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Logout", "Usuario")">Cerrar sesión</a>
                        </li>

                    </ul>

                    <span class="navbar-text text-white bi bi-person-badge-fill"> Usuario: @Session["Usuario"] - Rol: Admin</span>
                </div>
            </div>
        </nav>
    }
    @* -------------------------------------------------------------------------------------------------------- *@



    @* -------------------------------------------- USUARIO MEDICO -------------------------------------------- *@

    @if (Session["Usuario"] != null && Convert.ToInt32(Session["Rol"]) == 2)
    {
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-success">
            <div class="container">
                @Html.ActionLink(" Sistema Hospitalario", "Dashboard", "Home", new { area = "" }, new { @class = "navbar-brand bi bi-hospital-fill" })
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContenido2"
                        aria-controls="navbarContenido2" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse d-sm-inline-flex justify-content-between" id="navbarContenido2">

                    <ul class="navbar-nav flex-grow-1">

                        <li>@Html.ActionLink("Inicio", "Dashboard", "Home", new { area = "" }, new { @class = "nav-link" })</li>



                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="citas_tratamientosDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Citas y tratamiento
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="citas_tratamientosDropdown">
                                <li>@Html.ActionLink("Citas", "mantCitas", "Cita", new { area = "" }, new { @class = "dropdown-item" })</li>
                                <li>@Html.ActionLink("Tratamientos", "mantTratamientos", "Tratamiento", new { area = "" }, new { @class = "dropdown-item" })</li>
                            </ul>
                        </li>

                        <li>@Html.ActionLink("Ver Pacientes", "verPacientes", "Medico", new { area = "" }, new { @class = "nav-link" })</li>
                        <li>@Html.ActionLink("Pagos Pendientes", "verPagosPaciente", "Pago", new { area = "" }, new { @class = "nav-link" })</li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="datosDrDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Mis Datos (DR)
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="datosDrDropdown">
                                <li>@Html.ActionLink("Datos Personales", "actualizarDatosContacto", "Medico", new { area = "" }, new { @class = "dropdown-item" })</li>
                                <li>@Html.ActionLink("Datos de Usuario", "cambiarContrasena", "Usuario", new { area = "" }, new { @class = "dropdown-item" })</li>
                            </ul>
                        </li>

                        <li>
                            <a class="nav-link" href="@Url.Action("Logout", "Usuario")">Cerrar sesión</a>
                        </li>

                        <span class="navbar-text text-white bi bi-person-badge-fill"> Usuario: @Session["Usuario"] - Rol: Médico</span>

                    </ul>
                </div>
            </div>
        </nav>
    }

    @* -------------------------------------------------------------------------------------------------------- *@



    @* -------------------------------------------- USUARIO PACIENTE -------------------------------------------- *@
    @if (Session["Usuario"] != null && Convert.ToInt32(Session["Rol"]) == 1)
    {

        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-success">
            <div class="container">
                @Html.ActionLink(" Sistema Hospitalario", "Dashboard", "Home", new { area = "" }, new { @class = "navbar-brand bi bi-hospital-fill" })
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContenido3"
                        aria-controls="navbarContenido3" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">

                        <li>@Html.ActionLink("Inicio", "Dashboard", "Home", new { area = "" }, new { @class = "nav-link" })</li>
                        <li>@Html.ActionLink("Mis Citas", "verCitas", "Cita", new { area = "" }, new { @class = "nav-link" })</li>
                        <li>@Html.ActionLink("Pago pendientes", "verPagosPendientes", "Pago", new { area = "" }, new { @class = "nav-link" })</li>
                        <li>@Html.ActionLink("Mis Tratamientos", "verTratamientos", "Tratamiento", null, new { @class = "nav-link" })</li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="datosPacDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Mis datos (Paciente)
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="datosPacDropdown">
                                <li>@Html.ActionLink("Datos de Usuario", "cambiarContrasena", "Usuario", new { area = "" }, new { @class = "dropdown-item" })</li>
                                <li>@Html.ActionLink("Datos Personales", "actualizarDatosContacto", "Paciente", new { area = "" }, new { @class = "dropdown-item" })</li>
                            </ul>
                        </li>

                        <li>
                            <a class="nav-link" href="@Url.Action("Logout", "Usuario")">Cerrar sesión</a>
                        </li>

                        <span class="navbar-text text-white bi bi-person-badge-fill"> Usuario: @Session["Usuario"] - Rol: Paciente</span>

                    </ul>
                </div>
            </div>
        </nav>
    }

    @* -------------------------------------------------------------------------------------------------------- *@


    <div class="container body-content">
        @RenderBody()

    </div>
    <br /><br />
    <footer class="bg-success text-white mt-auto py-4">
        <div class="container text-center">
            <div class="mb-2">
                <p class="mb-0">&copy; @DateTime.Now.Year - <strong>JSM</strong> - Sistema Gestor de Hospitales</p>
            </div>
        </div>
    </footer>

    @*@Scripts.Render("~/bundles/jquery")
        @Scripts.Render("~/bundles/bootstrap")*@

    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("scripts", required: false)
</body>
</html>

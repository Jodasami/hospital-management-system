@model Sistema_Hospitales.Models.viewModels.mPaciente
@{
    ViewBag.Title = "actualizarDatosContacto";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>actualizarDatosContacto</h2>
<br />
<br />

@if (ViewBag.ValorMensaje == 1)
{

    <div class="modal fade" id="myModal" role="dialog">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                    <div class="modal-title">Mensaje</div>
                </div>
                <div class="modal-body">
                    <div class="alert alert-success">@ViewBag.MensajeProceso</div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-default" data-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}
else
{
    if (ViewBag.ValorMensaje == 0)
    {
        <div class="modal fade" id="myModal" role="dialog">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal">&times;</button>
                        <div class="modal-title">Mensaje</div>
                    </div>
                    <div class="modal-body">
                        <div class="alert alert-danger">@ViewBag.MensajeProceso</div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-default" data-dismiss="modal">Cerrar</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@using (Html.BeginForm("actualizarDatosContacto", "Paciente", FormMethod.Post))
{

    <div class="row">
        <div class="col-md-4">
            <input type="submit" class="btn btn-success btn-block btn-lg" value="Actualizar Datos" />

            <br />

            <input type="button" value="Volver" class="btn btn-secondary btn-lg" onclick="document.location.href = '@Url.Content("~/Home/Dashboard")'" />
        </div>

        <div class="col-md-8">

            @Html.HiddenFor(u => u.IdPaciente)

            @Html.HiddenFor(u => u.Nombre)

            @Html.HiddenFor(u => u.Apellido)

            @Html.HiddenFor(u => u.FechaNacimiento)

            @Html.HiddenFor(u => u.Genero)

            @Html.LabelFor(u => u.Direccion)
            @Html.TextBoxFor(u => u.Direccion, new { @class = "form-control" })
            @Html.ValidationMessage("Direccion")
            <br /><br />

            @Html.LabelFor(u => u.Telefono)
            @Html.TextBoxFor(u => u.Telefono, new { @class = "form-control" })
            @Html.ValidationMessage("Telefono")
            <br /><br />

            @Html.HiddenFor(u => u.IdHospital)

        </div>
    </div>
}

@section scripts {
    <script type="text/javascript">
        $(document).ready(function () {
            if (@ViewBag.ValorMensaje == 1 || @ViewBag.ValorMensaje == 0) {
                $('#myModal').modal('show');
            }

            // Cerrar modal manualmente si el botón no funciona
            $(".close, .btn-default").on("click", function () {
                $("#myModal").modal("hide");
            });
        });
    </script>
}




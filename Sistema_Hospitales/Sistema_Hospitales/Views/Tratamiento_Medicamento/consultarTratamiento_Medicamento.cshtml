@model Sistema_Hospitales.Models.viewModels.mTratamiento_Medicamento
@{
    ViewBag.Title = "consultarTratamiento_Medicamento";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-success text-white text-center">
                    <h3 class="mb-0">Detalle de Tratamiento/Medicamento</h3>
                </div>
                <div class="card-body p-3">
                    <div class="d-flex justify-content-center">
                        <!-- Contenedor centrado -->
                        <div class="table-responsive">
                            <!-- Ancho controlado -->
                            <table class="table table-borderless mx-auto">
                                <!-- mx-auto para centrar -->
                                <tbody>
                                    <tr>
                                        <th class="text-end">ID Tratamiento:</th>
                                        <td>@Html.DisplayFor(model => model.IdTratamiento)</td>
                                    </tr>
                                    <tr>
                                        <th class="text-end">ID Medicamento:</th>
                                        <td>@Html.DisplayFor(model => model.IdMedicamento)</td>
                                    </tr>
                                    <tr>
                                        <th class="text-end">Cantidad:</th>
                                        <td>@Html.DisplayFor(model => model.Cantidad)</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="text-center mt-4">
                        <a href="@Url.Content("~/Tratamiento_Medicamento/mantTratamiento_Medicamento")"
                           class="btn btn-secondary btn-lg">
                            Volver
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
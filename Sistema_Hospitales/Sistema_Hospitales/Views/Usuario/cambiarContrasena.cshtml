@model Sistema_Hospitales.Models.viewModels.mUsuario
@{
    ViewBag.Title = "cambiarContrasena";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>cambiarContrasena</h2>
<br />
<br />

@if (ViewBag.ValorMensaje == 1)
{
    <div class="modal fade" id="myModal" role="dialog">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                    <div class="modal-title">Mensaje</div>
                </div>
                <div class="modal-body">
                    <div class="alert alert-success">@ViewBag.MensajeProceso</div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-default" data-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}
else if (ViewBag.ValorMensaje == 0)
{
    <div class="modal fade" id="myModal" role="dialog">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                    <div class="modal-title">Mensaje</div>
                </div>
                <div class="modal-body">
                    <div class="alert alert-danger">@ViewBag.MensajeProceso</div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-default" data-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

@using (Html.BeginForm("cambiarContrasena", "Usuario", FormMethod.Post))
{
    <div class="row">
        <div class="col-md-4">
            <input type="submit" class="btn btn-success btn-block btn-lg" value="Actualizar Usuario" />
            <br />
            <input type="button" value="Volver" class="btn btn-secondary btn-lg" onclick="document.location.href = '@Url.Content("~/Home/Dashboard")'" />
        </div>

        <div class="col-md-8">

            @Html.HiddenFor(u => u.IdUsuario)

            @Html.HiddenFor(u => u.UserName)

            @Html.LabelFor(u => u.Contrasena)
            @Html.TextBoxFor(u => u.Contrasena, new { @class = "form-control" })
            @Html.ValidationMessageFor(u => u.Contrasena)
            <br /><br />

            @Html.HiddenFor(u => u.IdRol)

            @Html.HiddenFor(u => u.IdPaciente)

            @Html.HiddenFor(u => u.IdMedico)
        </div>
    </div>
}

@section scripts {
    <script type="text/javascript">
        $(document).ready(function () {
            if (@ViewBag.ValorMensaje == 1 || @ViewBag.ValorMensaje == 0) {
                $('#myModal').modal('show');
            }

            $(".close, .btn-default").on("click", function () {
                $("#myModal").modal("hide");
            });
        });
    </script>
}



@model Sistema_Hospitales.Models.viewModels.mUsuario
@{
    ViewBag.Title = "Home Page";
}

<div class="container d-flex justify-content-center align-items-center min-vh-100">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-lg border-0 rounded-4 p-4 custom-card-bg">
            <h3 class="text-center mb-4 text-success">Bienvenido al Sistema Hospitalario</h3>

            @using (Html.BeginForm("Login", "Usuario", FormMethod.Post))
            {
                <div class="form-floating mb-3">
                    @Html.TextBoxFor(m => m.UserName, new { @class = "form-control", placeholder = "Usuario" })
                    @Html.LabelFor(m => m.UserName)
                </div>

                <div class="form-floating mb-4">
                    @Html.PasswordFor(m => m.Contrasena, new { @class = "form-control", placeholder = "Contraseña" })
                    @Html.LabelFor(m => m.Contrasena)
                </div>

                <button type="submit" class="btn btn-success w-100 py-2">Iniciar Sesión</button>
            }

            @if (TempData["LoginError"] != null)
            {
                <div class="alert alert-danger mt-3" role="alert">
                    @TempData["LoginError"]
                </div>
            }

            <div class="text-center mt-4">
                <small class="text-muted">JSM - desarrollado en ASP.NET MVC</small>
            </div>
        </div>
    </div>
</div>
@model Sistema_Hospitales.Models.viewModels.mTratamiento
@{
    ViewBag.Title = "consultarTratamientos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-success text-white text-center">
                    <h3 class="mb-0">Consultar Tratamiento</h3>
                </div>
                <div class="card-body p-3">
                    <div class="d-flex justify-content-center">
                        <div class="table-responsive">
                            <table class="table table-borderless mx-auto">
                                <tbody>
                                    <tr>
                                        <th class="text-end">Paciente:</th>
                                        <td>@ViewBag.NombrePaciente</td>
                                    </tr>
                                    <tr>
                                        <th class="text-end">ID Tratamiento:</th>
                                        <td>@Html.DisplayFor(model => model.IdTratamiento)</td>
                                    </tr>
                                    <tr>
                                        <th class="text-end">ID Cita:</th>
                                        <td>@Html.DisplayFor(model => model.IdCita)</td>
                                    </tr>
                                    <tr>
                                        <th class="text-end">Costo Total:</th>
                                        <td>@Html.DisplayFor(model => model.CostoTotal)</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="text-center mt-4">
                        <input type="button" value="Volver" class="btn btn-secondary btn-lg"
                               onclick="document.location.href = '@Url.Content("~/Tratamiento/mantTratamientos")'" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
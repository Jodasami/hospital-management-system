@model List<Sistema_Hospitales.Models.viewModels.mTratamiento>
@{
    ViewBag.Title = "mantTratamientos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container mt-4">
    <h2 class="fw-bold text-dark align-content-center">Gestionar Tratamientos</h2>
    <br />

    <div class="d-flex justify-content-between align-items-center mb-4">
        <a href="@Url.Action("agregarTratamientos", "Tratamiento")" class="btn btn-success btn-lg">
            Agregar
        </a>
        <input type="button" value="Volver" class="btn btn-secondary btn-lg" onclick="document.location.href = '@Url.Content("~/Home/Dashboard")'" />
    </div>

    <div class="table-responsive shadow rounded-4 bg-secondary p-3" style="max-height: 500px; overflow-y: auto;">
        <table class="table table-hover table-secondary table-striped align-middle">
            <thead class="table-dark">
                <tr>
                    <th class="text-center">ID</th>
                    <th class="text-center">ID Cita - Paciente - Cedula</th>
                    <th class="text-center">Costo Total</th>
                    <th class="text-center">Detalles</th>
                    <th class="text-center">Editar</th>
                    <th class="text-center">Eliminar</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var fila in Model)
                {
                    <tr class="text-center">
                        <td>@fila.IdTratamiento</td>
                        <td>@fila.IdCita - @fila.NombrePaciente</td>
                        <td>@fila.CostoTotal</td>
                        <td>
                            <a class="btn btn-outline-dark btn-sm"
                               href="@Url.Action("consultarTratamientos", "Tratamiento", new { id = fila.IdTratamiento })">
                                Ver
                            </a>
                        </td>
                        <td>
                            <a class="btn btn-outline-primary btn-sm"
                               href="@Url.Action("actualizarTratamientos", "Tratamiento", new { id = fila.IdTratamiento })">
                                Editar
                            </a>
                        </td>
                        <td>
                            <button type="button" class="btn btn-outline-danger btn-sm open-delete-modal"
                                    data-id="@fila.IdTratamiento"
                                    data-nombre="Tratamiento @fila.IdTratamiento - Cita @fila.IdCita">
                                Eliminar
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal de confirmación -->
<div class="modal fade" id="confirmDeleteModal" tabindex="-1" role="dialog" aria-labelledby="confirmDeleteLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="confirmDeleteLabel">Confirmar eliminación</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                ¿Estás seguro de que deseas eliminar el tratamiento <strong id="idTratamiento"></strong>
                (ID Cita: <strong id="idCita"></strong>)?
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
                <a href="#" id="btnConfirmDelete" class="btn btn-danger">Eliminar</a>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>

    <script type="text/javascript">
$(document).ready(function () {
    $('#confirmDeleteModal').on('show.bs.modal', function (event) {
        var button = $(event.relatedTarget); // Botón que abrió el modal
        var tratamientoId = button.data('id');       // ← aquí corregido
        var citaId = button.data('nombre');          // ← aquí corregido

        $('#idTratamiento').text(tratamientoId);
        $('#idCita').text(citaId);

        var url = '@Url.Action("eliminarTratamientos", "Tratamiento")' + '?id=' + tratamientoId;
        $('#btnConfirmDelete').attr('href', url);
    });
});
    </script>


}




